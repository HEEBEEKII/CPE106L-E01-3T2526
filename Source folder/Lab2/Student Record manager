def main():
    # Dictionary to store student data: { student_id: (name, [grades]) }
    # Uses Strings (names), Lists (grades), Tuples (record structure), and Dictionary (storage)
    students = {}

    while True:
        print("\n--- Student Management System ---")
        print("1. Add Student (Create)")
        print("2. View All Students (Read)")
        print("3. Update Student Grades (Update)")
        print("4. Delete Student (Delete)")
        print("5. Exit")
        
        choice = input("Select an option: ")

        if choice == '1':
            s_id = input("Enter Student ID: ").strip()
            name = input("Enter Student Name: ").strip()
            # Storing as a Tuple containing a String and an empty List
            students[s_id] = (name, [])
            print(f"Student {name} added successfully.")

        elif choice == '2':
            if not students:
                print("No records found.")
            else:
                print("\nID\t| Name\t\t| Grades")
                print("-" * 30)
                for s_id, data in students.items():
                    # Unpacking the Tuple
                    name, grades = data
                    print(f"{s_id}\t| {name}\t| {grades}")

        elif choice == '3':
            s_id = input("Enter Student ID to update: ")
            if s_id in students:
                new_grade = input("Enter new grade to add: ")
                # Accessing the list inside the tuple and appending
                students[s_id][1].append(new_grade)
                print("Grade updated.")
            else:
                print("Student ID not found.")

        elif choice == '4':
            s_id = input("Enter Student ID to delete: ")
            if s_id in students:
                removed_student = students.pop(s_id)
                print(f"Record for {removed_student[0]} deleted.")
            else:
                print("Student ID not found.")

        elif choice == '5':
            print("Exiting program.")
            break
        else:
            print("Invalid choice. Please try again.")

if __name__ == "__main__":
    main()